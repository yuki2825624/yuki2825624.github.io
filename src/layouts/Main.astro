---
import Sidebar from "@/layouts/Sidebar.astro";
import Footer from "@/layouts/Footer.astro";

export interface Props {
    showNav?: boolean;
}

const { showNav = false } = Astro.props;
---

<div class="max-w-screen min-h-full rounded-2xl flex gap-2 m-2 lg:bg-wrap lg:p-2">
    {
        showNav && (
            <div class="min-h-full not-lg:hidden">
                <Sidebar />
            </div>
        )
    }

    <div class="flex flex-col flex-1">
        <div class="flex flex-col bg-sub pattern-dots-xl pattern-color-gray-50 rounded-xl flex-1 p-6 text-on-sub gap-16">
            <slot />
        </div>

        <Footer />
    </div>
</div>
