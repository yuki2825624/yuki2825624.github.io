---
import "@/styles/global.css";
import "@/styles/old.css";
import Header from "@/layouts/Header.astro";
import Main from "@/layouts/Main.astro";

export interface Props {
    title: string;
    showLogo?: boolean;
    showNav?: boolean;
}

const { title, showLogo = false, showNav = false } = Astro.props;
