<html lang="ja">
    <head>
        <title>yuki2825624</title>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta property="og:site_name" content="yuki2825624 Portfolio" />
        <meta property="og:title" content=`yuki2825624 Portfolio - ${title}` />
        <meta property="og:description" content="yukiのポートフォリオ用のサイトです。" />
        <meta property="og:url" content="https://yuki2825624.github.io/" />
        <meta property="og:image" content="https://yuki2825624.github.io/assets/icon.png" />
        <meta property="og:image:width" content="600" />
        <meta property="og:image:height" content="600" />
        <link rel="icon" href="/assets/icon.png" type="image/png" />
        <link rel="shortcut icon" href="/assets/icon.png" type="image/png" />
    </head>

    <body>
        <Header showLogo={showLogo} />
        <Main showNav={showNav}>
            <slot />
        </Main>
    </body>
</html>
