---
const { title, href } = Astro.props;
---

<div class="flex flex-col p-8 gap-20">
    <h2 class="relative text-title text-5xl text-shadow-title font-extralight pl-80 mt-20 before:content-[''] before:absolute before:top-1/2 before:left-8 before:w-64 before:h-px before:bg-title before:-translate-y-1/2 before:shadow-title">
        {title}
    </h2>
    <slot />
    <div class="flex items-center justify-center">
        <a href={href} class="flex items-center w-80 p-1.5 border-[0.3rem] border-gray-400 rounded-full text-center">
            <p class="flex-1 m-0 text-[1.2rem] text-gray-800">全て見る</p>
            <div class="relative flex items-center justify-center w-20 h-20 rounded-full border-[0.3rem] border-green-500 bg-white text-white transition-all duration-500 group hover:bg-green-500 hover:text-white">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-green-500 transition-all duration-400 group-hover:text-white group-hover:rotate-90">
                    <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
            </div>
        </a>
    </div>
</div>
